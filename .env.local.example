# ---------------------
# Runtime gateway (Telegram-only)
# ---------------------
# Host secret references (optional)
# - Plain values still work, but prefer storing secrets in macOS Keychain or 1Password.
# - Keychain example:
#   ANTHROPIC_API_KEY_KEYCHAIN_SERVICE=nanoclaw
#   ANTHROPIC_API_KEY_KEYCHAIN_ACCOUNT=ANTHROPIC_API_KEY
# - 1Password example:
#   ANTHROPIC_API_KEY_OP_REF=op://Private/NanoClaw/ANTHROPIC_API_KEY
# compose scripts resolve *_KEYCHAIN_* or *_OP_REF when the real env var is empty.
# After migrating secrets, run compose through `bash scripts/runtime/compose.sh ...`
# instead of calling `docker compose --env-file .env.local ...` directly.
LLM_PROXY_URL=http://127.0.0.1:8001
INTERNAL_API_TOKEN=replace-with-strong-internal-token
INTERNAL_SIGNING_SECRET=replace-with-strong-signing-secret
INTERNAL_NONCE_TTL_SEC=300
INTERNAL_NONCE_MAX_ENTRIES=10000
INTERNAL_RATE_LIMIT_PER_MINUTE=120
INTERNAL_RATE_LIMIT_WINDOW_SEC=60

# ---------------------
# llm-proxy model routing
# ---------------------
LLM_PROVIDER=auto
GEMINI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
ANTHROPIC_API_BASE=https://api.anthropic.com
ANTHROPIC_VERSION=2023-06-01
MODEL_MINERVA=gemini-2.0-flash
MODEL_CLIO=gemini-2.0-flash-lite
MODEL_HERMES=gemini-2.0-flash
MODEL_FALLBACK_MINERVA=gemini-2.0-flash-lite
MODEL_FALLBACK_CLIO=gemini-2.5-flash
MODEL_FALLBACK_HERMES=gemini-2.5-flash
MODEL_MAX_RETRIES=3
MODEL_REQUEST_TIMEOUT_SEC=20
MODEL_RETRY_BACKOFF_SEC=0.6
MODEL_RETRY_BACKOFF_MAX_SEC=4.0
MODEL_TEMPERATURE=0.3
MODEL_MAX_OUTPUT_TOKENS=768
SEARCH_PROVIDER=auto
SEARCH_TIMEOUT_SEC=8
TAVILY_API_KEY=
TAVILY_API_BASE=https://api.tavily.com
TAVILY_API_ALLOWED_HOSTS=api.tavily.com
TAVILY_SEARCH_DEPTH=basic

# ---------------------
# Minerva orchestration / Telegram UX
# ---------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_WEBHOOK_PUBLIC_BASE=
TELEGRAM_ALLOWED_CHAT_IDS=
TELEGRAM_ALLOWED_USER_IDS=
TELEGRAM_ALLOWED_CALLBACK_ACTIONS=clio_save,hermes_deep_dive,minerva_insight
TELEGRAM_API_BASE_URL=https://api.telegram.org
TELEGRAM_API_TIMEOUT_MS=8000
TELEGRAM_POLLER_STATE_PATH=shared_data/shared_memory/telegram_poller_state.json
TELEGRAM_POLLER_DEAD_LETTER_PATH=shared_data/logs/telegram_poller_dead_letter.jsonl
TELEGRAM_POLLER_REPLAY_ARCHIVE_PATH=shared_data/logs/telegram_poller_replayed.jsonl
TELEGRAM_APPROVAL_QUEUE_ENABLED=true
TELEGRAM_APPROVAL_REQUIRED_ACTIONS=clio_save,hermes_deep_dive,minerva_insight
TELEGRAM_APPROVAL_REQUIRED_STEPS=2
TELEGRAM_APPROVAL_TTL_SEC=300
TELEGRAM_APPROVAL_RETENTION_HOURS=72
INTERNAL_APP_BASE_URL=http://127.0.0.1:8001
TELEGRAM_TEXT_RATE_LIMIT_WINDOW_SEC=60
TELEGRAM_TEXT_RATE_LIMIT_MAX=12
TELEGRAM_MINERVA_TIMEOUT_MS=12000
TELEGRAM_MINERVA_RETRY_MAX=2
TELEGRAM_MINERVA_HISTORY_TURNS=10
MEMORY_MD_MAX_BYTES=280000
AGENT_MEMORY_MD_MAX_BYTES=120000
MEMORY_SKIP_TAGS=verification,rehearsal,test,smoke
COMPACT_MEMORY_MAX_ENTRIES=900
MINERVA_WORKING_MEMORY_MAX_CHARS=1800
CHAT_MEMORY_CONTEXT_ENABLED=true
CHAT_MEMORY_CONTEXT_AGENTS=minerva
CHAT_MEMORY_CONTEXT_MAX_CHARS=900
CHAT_MEMORY_CONTEXT_MAX_BLOCKS=4
CHAT_MEMORY_CONTEXT_MAX_ITEMS=4
MINERVA_IMMEDIATE_MIN_PRIORITY=high
MINERVA_IMMEDIATE_MIN_CONFIDENCE=0.80
MINERVA_TOPIC_COOLDOWN_HOURS=8
MINERVA_DIGEST_SLOTS=09:00,18:00
MINERVA_MORNING_INCLUDE_CALENDAR=true
MINERVA_BRIEFING_TIMEZONE=Asia/Seoul
ORCH_REQUIRE_SCHEMA_V1=false

# ---------------------
# External integrations (read-only / translation)
# ---------------------
GOOGLE_CALENDAR_ENABLED=false
GOOGLE_CALENDAR_READONLY=true
GOOGLE_CALENDAR_ID=primary
GOOGLE_CALENDAR_OAUTH_CLIENT_ID=
GOOGLE_CALENDAR_OAUTH_CLIENT_SECRET=
GOOGLE_CALENDAR_OAUTH_REDIRECT_URI=http://127.0.0.1:8001/api/integrations/google-calendar/oauth/callback
GOOGLE_CALENDAR_OAUTH_SCOPES=https://www.googleapis.com/auth/calendar.readonly
GOOGLE_CALENDAR_TOKEN_PATH=shared_data/shared_memory/google_calendar_tokens.json
GOOGLE_CALENDAR_STATE_PATH=shared_data/shared_memory/google_calendar_oauth_state.json
GOOGLE_CALENDAR_ATTACH_TO_MORNING_BRIEFING=true
DEEPL_API_KEY=
DEEPL_TARGET_LANG=KO
DEEPL_GLOSSARY_ID=
# 번역 최적화 정책(코드 고정): P0 summary+2 snippets / P1 summary+1 snippet / P2 none

# ---------------------
# n8n
# ---------------------
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
N8N_WEBHOOK_URL=http://localhost:5678
N8N_ENCRYPTION_KEY=replace-with-n8n-encryption-key
N8N_RUNNERS_ENABLED=true
N8N_ENFORCE_SETTINGS_FILE_PERMISSIONS=false
# n8n v1+에서는 BASIC_AUTH 설정이 제거되어 실제 보호는 user-management + ingress에서 수행
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=replace-with-n8n-admin-user
N8N_BASIC_AUTH_PASSWORD=replace-with-strong-n8n-password
ORCHESTRATION_EVENT_URL=http://llm-proxy:8000/api/orchestration/events
HERMES_AUTO_CLIO_SAVE=true
HERMES_AUTO_CLIO_SAVE_MIN_IMPACT=0.75
HERMES_SEARCH_PROVIDER=auto
HERMES_DEEP_DIVE_AUTO_MINERVA=true
NOTEBOOKLM_SYNC_ENABLED=false
NOTEBOOKLM_INGEST_WEBHOOK_URL=
NOTEBOOKLM_API_KEY=
NOTEBOOKLM_TIMEOUT_SEC=8

# Optional host-secret reference examples
# TELEGRAM_BOT_TOKEN_KEYCHAIN_SERVICE=nanoclaw
# TELEGRAM_BOT_TOKEN_KEYCHAIN_ACCOUNT=TELEGRAM_BOT_TOKEN
# TELEGRAM_WEBHOOK_SECRET_KEYCHAIN_SERVICE=nanoclaw
# TELEGRAM_WEBHOOK_SECRET_KEYCHAIN_ACCOUNT=TELEGRAM_WEBHOOK_SECRET
# GOOGLE_CALENDAR_OAUTH_CLIENT_ID_OP_REF=op://Private/NanoClaw/GOOGLE_CALENDAR_OAUTH_CLIENT_ID
# GOOGLE_CALENDAR_OAUTH_CLIENT_SECRET_OP_REF=op://Private/NanoClaw/GOOGLE_CALENDAR_OAUTH_CLIENT_SECRET
